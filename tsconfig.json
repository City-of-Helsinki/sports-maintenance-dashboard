{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "es6"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["jest", "@testing-library/jest-dom", "node"],
    "baseUrl": "./src",
    "paths": {
      "styles/*": ["./styles/*"],
      "components/*": ["./components/*"],
      "actions/*": ["./actions/*"],
      "reducers/*": ["./reducers/*"],
      "lib/*": ["./lib/*"],
      "util/*": ["./util/*"],
      "constants/*": ["./constants/*"],
      "config/*": ["./config/*"],
      "hooks/*": ["./hooks/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "cfg"
  ]
}